{
    "$schema": "https://raw.githubusercontent.com/judegordon/hgps/main/schemas/config/config.json",
    "project_requirements": {
        "demographics": {
            "age": true,
            "gender": true,
            "region": true,
            "ethnicity": true
        },
        "income": {
            "enabled": true,
            "type": "categorical",
            "categories": 4,
            "adjust_to_factors_mean": true,
            "trended": false
        },
        "physical_activity": {
            "enabled": true,
            "type": "continuous",
            "adjust_to_factors_mean": true,
            "trended": false
        },
        "risk_factors": {
            "adjust_to_factors_mean": true,
            "trended": false
        },
        "trend": {
            "enabled": false,
            "type": "none"
        },
        "two_stage": {
            "use_logistic": false
        }
    },
    "data": {
        "source": "https://github.com/imperialCHEPI/healthgps-data/releases/download/finch-v4/data.zip",
        "checksum": "b8bef3b1f916b5cdc6497550947ae140661d2294b9a3ff61d65ce4098d46ecfc"
    },
    "inputs": {
        "dataset": {
            "name": "../Finch.DataFile.csv",
