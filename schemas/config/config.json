{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/judegordon/hgps/main/schemas/config/config.json",
  "type": "object",
  "description": "Root configuration for a HealthGPS simulation.",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema identifier."
    },
    "version": {
      "type": "string",
      "const": "baseline",
      "description": "Configuration schema version."
    },
    "project_requirements": {
      "$ref": "../components/config/project_requirements.json"
    },
    "data": {
      "$ref": "../components/config/data.json"
    },
    "inputs": {
      "$ref": "../components/config/inputs.json"
    },
    "modelling": {
      "$ref": "../components/config/modelling.json"
    },
    "running": {
      "$ref": "../components/config/running.json"
    },
    "output": {
      "$ref": "../components/config/output.json"
    },
    "population_impact_fraction": {
      "$ref": "../components/config/population_impact_fraction.json"
    }
  },
  "required": [
    "version",
    "project_requirements",
    "data",
    "inputs",
    "modelling",
    "running",
    "output"
  ],
  "additionalProperties": false
}