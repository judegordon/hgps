{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/judegordon/hgps/main/schemas/data_index/components/disease.json",
  "type": "object",
  "description": "File references and metadata for a single disease dataset.",
  "properties": {
    "path": {
      "type": "string",
      "description": "Directory path where disease data is stored."
    },
    "file_name": {
      "type": "string",
      "description": "File name for the disease dataset."
    },
    "relative_risk": {
      "type": "object",
      "description": "Relative risk data files linking diseases and risk factors.",
      "properties": {
        "path": {
          "type": "string"
        },
        "to_disease": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "file_name": {
              "type": "string"
            },
            "default_value": {
              "type": "number"
            }
          },
          "required": [
            "path",
            "file_name",
            "default_value"
          ],
          "additionalProperties": false
        },
        "to_risk_factor": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "file_name": {
              "type": "string"
            }
          },
          "required": [
            "path",
            "file_name"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "path",
        "to_disease",
        "to_risk_factor"
      ],
      "additionalProperties": false
    },
    "population_impact_fraction": {
      "$ref": "../../defs/disease_population_impact_fraction_file.json"
    },
    "parameters": {
      "type": "object",
      "description": "Disease parameter files used by the simulation.",
      "properties": {
        "path": {
          "type": "string"
        },
        "files": {
          "type": "object",
          "properties": {
            "distribution": {
              "type": "string"
            },
            "survival_rate": {
              "type": "string"
            },
            "death_weight": {
              "type": "string"
            }
          },
          "required": [
            "distribution",
            "survival_rate",
            "death_weight"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "path",
        "files"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "path",
    "file_name",
    "relative_risk",
    "parameters"
  ],
  "additionalProperties": false
}